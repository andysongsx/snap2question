.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100vh;
  background: #1a1a1a;
  padding: 16rpx 0 20rpx;
}

.tip-bar {
  padding: 12rpx 20rpx;
  margin-bottom: 12rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.rotate-hint {
  color: #07c160;
  font-size: 24rpx;
  background: rgba(7, 193, 96, 0.15);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.tip-text {
  color: #fff;
  font-size: 28rpx;
  background: rgba(7, 193, 96, 0.2);
  padding: 10rpx 24rpx;
  border-radius: 40rpx;
}

.canvas-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  box-sizing: border-box;
  min-height: 0;
}

.main-canvas {
  display: block;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.3);
}

.action-bar {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 24rpx;
  margin-top: 24rpx;
  padding: 0 40rpx;
  width: 100%;
  box-sizing: border-box;
  flex-shrink: 0;
}

.btn-secondary,
.btn-rotate,
.btn-primary {
  height: 92rpx;
  line-height: 92rpx;
  font-size: 30rpx;
  border-radius: 16rpx;
  text-align: center;
  padding: 0;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-secondary::after,
.btn-rotate::after,
.btn-primary::after {
  border: none;
}

.btn-secondary {
  flex: 1;
  background: rgba(255,255,255,0.15);
  color: white;
  max-width: 200rpx;
}

.btn-rotate {
  flex: 0 0 auto;
  min-width: 140rpx;
  background: rgba(255,255,255,0.1);
  color: #ccc;
  font-size: 26rpx;
}

.btn-rotate:active {
  background: rgba(255,255,255,0.2);
}

.btn-primary {
  flex: 1.5;
  background: #07c160;
  color: white;
  max-width: 340rpx;
}

.btn-primary.disabled {
  background: #555;
  opacity: 0.5;
}

.btn-primary:not(.disabled):active {
  opacity: 0.85;
}

.btn-secondary:active {
  background: rgba(255,255,255,0.25);
}
