.header {
  text-align: center;
  padding: 40rpx 0 30rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #07c160;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #999;
}

/* 配置面板 */
.config-panel {
  padding: 20rpx 30rpx;
  margin: 0 0 30rpx;
  background: #fff;
}

.config-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.config-row:last-child {
  border-bottom: none;
}

.config-label {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.config-value {
  font-size: 30rpx;
  color: #07c160;
  display: flex;
  align-items: center;
}

.config-value .arrow {
  font-size: 20rpx;
  margin-left: 8rpx;
  color: #999;
}

.action-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 30rpx;
  margin: 20rpx 0 40rpx;
  background: linear-gradient(135deg, #07c160 0%, #05a350 100%);
  color: white;
  border-radius: 20rpx;
}

.action-card .icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.action-text {
  font-size: 36rpx;
  font-weight: 500;
  margin-bottom: 10rpx;
}

.action-desc {
  font-size: 24rpx;
  opacity: 0.9;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

.history-list {
  margin-bottom: 20rpx;
}

.history-item {
  position: relative;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.history-type {
  font-size: 24rpx;
  color: #07c160;
  background: rgba(7, 193, 96, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.history-time {
  font-size: 22rpx;
  color: #bbb;
}

.history-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.history-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
}

.delete-btn {
  font-size: 24rpx;
  color: #ff4d4f;
  padding: 8rpx 16rpx;
}

.clear-all {
  text-align: center;
  font-size: 26rpx;
  color: #999;
  padding: 20rpx;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 40rpx;
  color: #bbb;
  font-size: 28rpx;
}
