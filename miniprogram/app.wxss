page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
  background-color: #f5f5f5;
  color: #333;
}

.container {
  padding: 30rpx;
}

.btn-primary {
  background-color: #07c160;
  color: white;
  border-radius: 8rpx;
  padding: 24rpx 0;
  text-align: center;
  font-size: 32rpx;
  margin: 20rpx 0;
}

.btn-primary:active {
  opacity: 0.8;
}

.card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
}
